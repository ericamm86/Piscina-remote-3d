{
  "name": "piscina-remote-3d",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sistema web de sensoriamento remoto e visualizacao 3D para piscinas residenciais.",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -n API,WEB -c green,cyan \"npm run dev -w apps/api\" \"vite --host 0.0.0.0\"",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "npm run start -w apps/api",
    "lint": "eslint src --ext js,jsx --max-warnings 0",
    "test": "npm run test -w apps/api",
    "db:init": "npm run db:init -w apps/api"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-rnd": "^10.5.3",
    "three": "^0.171.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0"
  }
}
